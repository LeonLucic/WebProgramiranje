<!DOCTYPE html>
<html lang="hr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Filmbase</title>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <header id="Naslov">
    <h1>Dobrodošli na moju web stranicu</h1>
  </header>

  <nav class="navbar">
    <input type="checkbox" id="check">
    <label for="check" class="checkbtn">☰</label>

    <div class="nav-links">
      <a href="/">Početna</a>
      <a href="/grafikon">Grafikon</a>
      <a href="/slike">Galerija</a>
    </div>
  </nav>

  <main>
    <section id="lv3-filmovi">
      <h1>LV3 - Lista gledanja</h1>

      <div class="filteri">
        <input type="text" id="pretraga" placeholder="Pretraži film ili režisera">

        <select id="filter-zanr">
          <option value="">Svi žanrovi</option>
        </select>

        <input type="number" id="filter-godina" placeholder="Godina od">

        <label>
          Minimalna ocjena:
          <input type="range" id="filter-ocjena" min="0" max="10" step="0.1" value="0">
          <span id="ocjena-vrijednost">0</span>
        </label>

        <button id="reset-filtera">Reset</button>
      </div>

      <div class="lv3-layout">
        <table id="filmovi-lv3-tablica">
          <thead>
            <tr>
              <th>Naslov</th>
              <th>Žanr</th>
              <th>Godina</th>
              <th>Trajanje</th>
              <th>Ocjena</th>
              <th>Režiser</th>
              <th>Zemlja</th>
              <th>Akcija</th>
            </tr>
          </thead>
          <tbody></tbody>
        </table>

        <aside id="lista-gledanja">
          <h2>Moja lista gledanja</h2>
          <p id="broj-filmova">Broj filmova: 0</p>
          <ul id="lista-filmova"></ul>
          <button id="potvrdi-listu">Potvrdi listu</button>
          <p id="poruka-liste"></p>
        </aside>
      </div>
    </section>
  </main>

  <footer>
    <p>&copy; 2025. Web Programiranje. Sva prava pridržana.</p>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
  <script src="/script.js"></script>

</body>
</html>